  "keywords": [
    "game",
    "phaser",
    "brawl-stars",
    "battle-royale"
  ],
  "license": "MIT",
  "dependencies": {
    "@colyseus/ws-transport": "^0.16.5",
    "colyseus": "^0.16.5",
    "colyseus.js": "^0.16.22",
    "phaser": "^3.87.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
