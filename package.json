{
  "name": "projetnyxt",
  "version": "0.5.0",
  "description": "Projet Nyxt — jeu web type Brawl Stars (Battle Royale). Extensible : Zareks, cartes et modes pilotés par des données.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
